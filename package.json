{
  "name": "@qaz154/codescaffold",
  "version": "1.15.1",
  "description": "AI-Powered Full-Stack Project Scaffold Generator",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "codescaffold": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "node --import tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ci": "npm run build && playwright test",
    "test:templates": "node --import tsx src/scripts/validate-templates.ts"
  },
  "keywords": [
    "scaffold",
    "generator",
    "nextjs",
    "express",
    "prisma",
    "cli"
  ],
  "author": "QAZ154",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "boxen": "^7.1.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "inquirer": "^9.2.16",
    "openai": "^4.73.0",
    "ora": "^8.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/inquirer": "^8.2.10",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitest/ui": "^3.0.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.0",
    "tsx": "^4.22.3",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
